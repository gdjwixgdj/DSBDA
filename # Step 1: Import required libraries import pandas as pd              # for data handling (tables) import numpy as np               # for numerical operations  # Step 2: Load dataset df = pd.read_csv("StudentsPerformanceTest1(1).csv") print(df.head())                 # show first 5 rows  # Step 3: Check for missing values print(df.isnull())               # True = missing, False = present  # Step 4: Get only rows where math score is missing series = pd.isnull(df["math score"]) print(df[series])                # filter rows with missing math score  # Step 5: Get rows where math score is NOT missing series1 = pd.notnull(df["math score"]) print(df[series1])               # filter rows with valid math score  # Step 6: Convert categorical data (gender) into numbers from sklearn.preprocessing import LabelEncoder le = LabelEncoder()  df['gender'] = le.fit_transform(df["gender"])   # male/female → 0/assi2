# Step 1: Import required libraries
import pandas as pd              # for data handling (tables)
import numpy as np               # for numerical operations

# Step 2: Load dataset
df = pd.read_csv("StudentsPerformanceTest1(1).csv")
print(df.head())                 # show first 5 rows

# Step 3: Check for missing values
print(df.isnull())               # True = missing, False = present

# Step 4: Get only rows where math score is missing
series = pd.isnull(df["math score"])
print(df[series])                # filter rows with missing math score

# Step 5: Get rows where math score is NOT missing
series1 = pd.notnull(df["math score"])
print(df[series1])               # filter rows with valid math score

# Step 6: Convert categorical data (gender) into numbers
from sklearn.preprocessing import LabelEncoder
le = LabelEncoder()

df['gender'] = le.fit_transform(df["gender"])  
# male/female → 0/1

print(df)

# Step 7: Define custom missing values like "Na", "na"
missing_values = ["Na", "na"]

# Reload dataset treating these as missing
df = pd.read_csv("StudentsPerformanceTest1(1).csv", na_values=missing_values)
print(df)

# Step 8: Fill ALL missing values with 0
ndf = df.copy()                  # create copy of dataset
print(ndf.fillna(0))             # fill missing with 0

# Step 9: Fill missing math score with mean
m_v = df['math score'].mean()    # calculate average
df['math score'].fillna(value=m_v, inplace=True)

print(df)

# Step 10: Fill missing reading score with median
me_v = df['reading score'].median()  # calculate median
df['reading score'].fillna(value=me_v, inplace=True)

print(df)

# Step 11: Fill missing writing score with standard deviation
std_v = df['writing score'].std()   # calculate standard deviation
df['writing score'].fillna(value=std_v, inplace=True)

print(df)

# Step 12: Fill missing Placement Score with minimum value
min_v = df['Placement Score'].min()
df['Placement Score'].fillna(value=min_v, inplace=True)

print(df)

# Step 13: Fill missing placement offer count with maximum value
max_v = df['placement offer count'].max()
df['placement offer count'].fillna(value=max_v, inplace=True)

print(df)

