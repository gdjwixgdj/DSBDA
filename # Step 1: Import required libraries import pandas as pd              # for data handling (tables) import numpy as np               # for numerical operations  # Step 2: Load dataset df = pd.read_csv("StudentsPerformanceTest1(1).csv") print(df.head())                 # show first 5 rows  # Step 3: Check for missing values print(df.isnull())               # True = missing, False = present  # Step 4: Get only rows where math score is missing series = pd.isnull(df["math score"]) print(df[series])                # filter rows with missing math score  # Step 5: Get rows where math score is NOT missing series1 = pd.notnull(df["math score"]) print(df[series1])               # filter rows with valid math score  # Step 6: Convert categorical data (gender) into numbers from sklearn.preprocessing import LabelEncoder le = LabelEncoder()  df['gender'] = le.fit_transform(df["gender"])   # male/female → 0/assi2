# Step 14: Load another dataset
df = pd.read_csv("demo1.csv")
print(df)

# Step 15: Install and import seaborn (only once needed)
# pip install seaborn   # run this in terminal, not in script
import seaborn as sns

# Step 16: Boxplot (to detect outliers)
col = ['math score', 'reading score', 'writing score', 'placement score']
df.boxplot(col)   # shows spread and outliers

# Step 17: Scatter plot (relationship between variables)
import matplotlib.pyplot as plt

fig, ax = plt.subplots(figsize=(10,6))
ax.scatter(df['placement score'], df['placement offer count'])
plt.xlabel("Placement Score")
plt.ylabel("Placement Offer Count")
plt.title("Scatter Plot")
plt.show()

# Step 18: Histogram (distribution of math score)
df['math score'].plot(kind='hist')
plt.title("Math Score Distribution")
plt.show()

# Step 19: Log transformation (reduce skewness)
df['log_math'] = np.log10(df['math score'])

# Plot histogram after transformation
df['log_math'].plot(kind='hist')
plt.title("Log Transformed Math Score")
plt.show()
